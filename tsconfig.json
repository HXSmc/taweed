{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "types": ["node"]
  },
  "include": [
    "packages/*/src/**/*.ts",
    "packages/*/test/**/*.ts",
    "test/synthetic-fhir/src/**/*.ts",
    "test/synthetic-fhir/test/**/*.ts",
    "vitest.workspace.ts",
    "eslint.config.js"
  ],
  "exclude": ["**/node_modules/**", "**/dist/**", "apps/**"]
}
